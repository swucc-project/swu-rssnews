{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "BaseUrl": "https://news.swu.ac.th",
  "ConnectionStrings": {
    "DefaultConnection": "Server=${DATABASE_HOST};Database=${DATABASE_NAME};User Id=sa;Password=${MSSQL_SA_PASSWORD};TrustServerCertificate=True;"
  },
  "AppSettings": {
    "PublicBaseUrl": "https://news.swu.ac.th",
    "GraphQLApiUrl": "/graphql",
    "GrpcApiUrl": "/grpc"
  },
  "Kestrel": {
    "Endpoints": {
      "Http": {
        "Url": "http://localhost:5000"
      },
      "https": {
        "Url": "https://localhost:5001"
      }
    },
    "EndpointDefaults": {
      "Protocols": "Http1AndHttp2"
    }
  },
  "GraphQL": {
    "EnablePlayground": true
  },
  "Inertia": {
    "SsrUrl": "http://localhost:13714/render"
  },
  "CorsOrigins": [
    "http://localhost",
    "https://localhost",
    "http://localhost:5000",
    "https://localhost:5001",
    "http://localhost:5173",
    "https://localhost:5173",
    "http://localhost:8080",
    "https://localhost:8080",
    "http://localhost:13714",
    "https://localhost:13714",
    "https://news.swu.ac.th"
  ],
  "Sentry": {
    "Dsn": ""
  },
  "DebugMode": true
}