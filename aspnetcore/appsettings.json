{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore": "Warning",
      "HotChocolate": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Kestrel": {
    "EndpointDefaults": {
      "Protocols": "Http1AndHttp2"
    }
  },
  "Vite": {
    "Manifest": {
      "PublicDirectory": "wwwroot",
      "BuildDirectory": "wwwroot/volume",
      "HotFile": "hot",
      "ManifestFilename": "manifest.json"
    }
  },
  "GraphQL": {
    "EnableIntrospection": false,
    "EnablePlayground": false
  },
  "Microsoft": {
    "AspNetCore": {
      "ForwardedHeaders": {
        "ForwardedHeaders": "All"
      }
    }
  },
  "Cors": {
    "AllowedOrigins": [
      "http://localhost:8080",
      "https://news.swu.ac.th"
    ]
  }
}