    "google-protobuf": "^3.21.4",
    "graphql": "^16.11.0",
    "graphql-tag": "^2.12.6",
    "graphql-ws": "^6.0.6",
    "grpc_tools_node_protoc_ts": "^5.3.3",
    "grpc-tools": "^1.13.0",
    "grpc-web": "^1.5.0",
    "is-url-http": "^2.3.12",
    "mitt": "^3.0.1",
    "openapi-types": "^12.1.3",
    "openapi-zod-client": "^1.18.3",
    "path-to-regexp": "^6.3.0",
