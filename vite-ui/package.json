{
  "name": "rssnews",
  "version": "1.0.0",
  "description": "RSS News Frontend with GraphQL and gRPC",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:docker": "vite --host 0.0.0.0 --port 5173",
    "build": "npm run graphql:ensure && vite build",
    "preview": "vite preview",
    "graphql:wait": "bash ./scripts/wait-for-graphql.sh",
    "graphql:ensure": "node scripts/assure-graphql-files.mjs",
    "graphql:codegen": "graphql-codegen --config apollo/codegen.ts",
    "graphql:codegen:safe": "npm run graphql:codegen || npm run graphql:ensure",
    "graphql:introspect": "bash ./scripts/install-graphql.sh",
    "graphql:generate": "npm run graphql:ensure && npm run graphql:codegen:safe",
    "graphql:setup": "npm run graphql:ensure && npm run graphql:introspect",
    "graphql:debug": "bash ./scripts/debug-graphql.sh",
    "graphql:validate": "bash ./scripts/validate-graphql.sh",
    "grpc:ensure": "node scripts/assure-grpc-files.mjs",
    "grpc:placeholders": "node scripts/create-grpc-placeholders.mjs",
    "grpc:generate": "node scripts/generate-grpc.mjs",
    "grpc:generate:safe": "npm run grpc:generate 2>/dev/null || npm run grpc:ensure",
    "grpc:sync": "node scripts/synchronize-grpc.mjs",
    "postgenerate-grpc": "npm run grpc:sync",
    "assure-files": "npm run graphql:ensure && npm run grpc:ensure",
    "codegen:watch": "graphql-codegen --config apollo/codegen.ts --watch",
    "rover:setup": "bash ./scripts/rover-setup.sh 2>/dev/null || true",
    "rover:introspect": "bash ./scripts/rover-introspect.sh",
    "rover:dev": "npm run rover:introspect && npm run graphql:codegen:safe",
    "setup": "npm run grpc:ensure && npm run graphql:ensure",
    "generate-api-client": "swagger-typescript-api -p ./api/swagger.json -o ./api/generated -n RssClient.ts --module-name-index 1 --extract-request-body --clean-output --templates ./api-templates",
    "generate-swagger-client": "swagger-typescript-api -p ./api/swagger.json -o ./api/generated -n rssFeedClient.ts --axios --route-types --unwrap-response-data --single-http-client",
    "generate-zod-client": "npm run generate-openapi-docs && openapi-zod-client ../aspnetcore/wwwroot/manual-api.json -o ./api/openapi-zod/news.ts -a",
    "prepare": "npm run setup",
    "lint": "eslint . --ext .ts,.tsx,.vue",
    "type-check": "vue-tsc --noEmit",
    "predev": "npm run graphql:ensure && npm run grpc:ensure",
    "prebuild": "npm run graphql:ensure && npm run grpc:ensure",
    "test": "vitest"
  },
  "keywords": [
    "rss",
    "news",
    "Srinakharinwirot University",
    "graphql",
    "grpc",
    "vue",
    "vite"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@bufbuild/protobuf": "^2.11.0",
    "@connectrpc/connect": "^2.1.1",
    "@connectrpc/connect-web": "^2.1.1",
    "@graphql-typed-document-node/core": "^3.2.0",
    "@grpc/grpc-js": "^1.13.4",
    "@grpc/proto-loader": "^0.8.0",
    "@improbable-eng/grpc-web": "^0.15.0",
    "@inertiajs/inertia": "^0.11.1",
    "@inertiajs/vue3": "^2.0.17",
    "@protobuf-ts/grpc-transport": "2.11.1",
    "@protobuf-ts/grpcweb-transport": "^2.11.1",
    "@protobuf-ts/runtime": "^2.11.1",
    "@protobuf-ts/runtime-rpc": "^2.11.1",
    "@speakeasy-api/speakeasy-client-sdk-typescript": "^3.3.15",
    "@vue/apollo-composable": "^4.2.2",
