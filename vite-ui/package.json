    "protoc-gen-grpc": "^3.0.0",
    "protoc-gen-grpc-web": "^1.5.0",
    "rimraf": "^6.1.0",
    "rollup": "^4.43.0",
    "rollup-plugin-copy": "^3.5.0",
    "rollup-plugin-peer-deps-external": "^2.2.4",
    "rollup-plugin-postcss": "^4.0.2",
    "rollup-plugin-terser": "^7.0.2",
