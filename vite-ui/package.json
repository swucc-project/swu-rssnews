{
  "name": "rssnews",
  "version": "1.0.0",
  "description": "",
  "main": "apollo.config.js",
  "scripts": {
    "dev": "npm run assure-files && vite --host",
    "dev:docker": "npm run assure-files && vite --host 0.0.0.0",
    "dev:ssr": "node hub/ssr-server.js",
    "clean": "rimraf ../aspnetcore/wwwroot/volume ../aspnetcore/wwwroot/ssr",
    "build": "npm run clean && npm run build:client && npm run build:ssr",
    "build:client": "vite build",
    "build:ssr": "vite build --ssr hub/ssr.js --outDir wwwroot/ssr",
    "preview": "vite preview",
    "start:ssr": "node hub/ssr-server.js",
    "start:ssr:dev": "NODE_ENV=development node hub/ssr-server.js",
    "start:ssr:prod": "NODE_ENV=production node hub/ssr-server.js",
    "start:prod": "npm run build && npm run start:ssr:prod",
    "docker:dev": "npm run wait-for-backend && npm run wait-for-graphql && npm run dev:docker",
    "docker:build": "npm run wait-for-backend && npm run build",
    "docker:graphql": "npm run wait-for-graphql && npm run graphql:setup",
    "docker:generate": "npm run wait-for-backend && npm run generate-all",
    "health": "node -e \"require('http').get('http://localhost:5173', (r) => process.exit(r.statusCode === 200 ? 0 : 1))\"",
    "health:ssr": "node -e \"require('http').get('http://localhost:13714/health', (r) => process.exit(r.statusCode === 200 ? 0 : 1))\"",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest --coverage",
    "lint": "eslint --ext .ts,.tsx,.js,.vue .",
    "lint:fix": "eslint --ext .ts,.tsx,.js,.vue . --fix",
    "type-check": "vue-tsc --noEmit",
    "prepare": "npm run assure-files",
    "postinstall": "npm run assure-files",
    "assure-files": "bash ./scripts/assure-graphql-files.sh",
    "codegen": "graphql-codegen --config apollo/codegen.ts || (echo '⚠️ Codegen failed' && exit 0)",
    "codegen:watch": "graphql-codegen --config apollo/codegen.ts --watch",
    "codegen:safe": "npm run assure-files && (npm run schema:download && npm run codegen || (echo '⚠️ Using placeholder files' && exit 0))",
    "schema:download": "bash ./scripts/download-schema.sh || (echo '⚠️ Schema download failed' && exit 0)",
    "schema:download:graphql-cli": "graphql get-schema --endpoint http://aspdotnetweb:5000/graphql --header 'X-Allow-Introspection=true' > apollo/schema.graphql || exit 0",
    "schema:download:rover": "rover graph introspect http://aspdotnetweb:5000/graphql --header 'X-Allow-Introspection:true' > apollo/schema.graphql || exit 0",
    "schema:check": "bash -c '[ -f apollo/schema.graphql ] && ! grep -q \"_placeholder\" apollo/schema.graphql' || exit 0",
    "schema:validate": "graphql-inspector validate apollo/**/*.graphql apollo/schema.graphql || (echo '⚠️ Validation skipped' && exit 0)",
    "rover:introspect": "rover graph introspect http://aspdotnetweb:5000/graphql --header 'X-Allow-Introspection:true' > apollo/schema.graphql || (echo '⚠️ Rover failed' && exit 0)",
    "rover:check": "rover graph check rssnews@development --schema apollo/schema.graphql || exit 0",
    "rover:publish": "rover graph publish rssnews@development --schema apollo/schema.graphql || exit 0",
    "rover:dev": "npm run rover:introspect && npm run codegen || exit 0",
    "graphql:setup": "npm run assure-files && npm run schema:download && npm run codegen || (echo '⚠️ GraphQL setup incomplete, using placeholders' && exit 0)",
    "graphql:generate": "npm run schema:download && npm run codegen || (echo '⚠️ Generation failed, using placeholders' && npm run assure-files && exit 0)",
    "graphql:reset": "rm -rf apollo/generated/* apollo/schema.graphql && npm run assure-files",
    "generate-graphql-client": "npm run codegen",
    "generate-graphql-client:fallback": "echo '⚠️ Using fallback GraphQL setup' && npm run assure-files",
    "generate-graphql-safe": "bash ./scripts/secure-graphql-client.sh || (npm run assure-files && exit 0)",
    "generate-grpc": "protoc --plugin=protoc-gen-ts=./node_modules/.bin/protoc-gen-ts --ts_out=long_type_string:./grpc --proto_path=./protobuf ./protobuf/rss.proto || exit 0",
    "sync-grpc": "bash ./scripts/unify-grpc.sh || exit 0",
    "generate-grpc-all": "npm run generate-grpc && npm run sync-grpc",
    "generate-swagger-api": "swagger-typescript-api -p https://localhost:5001/swagger/v1/swagger.json -o ./api/generated -n rssFeed.ts --axios || exit 0",
    "generate-openapi-docs": "tsx scripts/generate-openapi-docs.ts || exit 0",
    "generate-zod-client": "npm run generate-openapi-docs && tsx scripts/generate-typescript-client.ts || exit 0",
    "generate-all": "npm run generate-openapi-docs && npm run generate-zod-client",
    "docs:build": "npm run generate-zod-client",
    "wait-for-backend": "bash -c 'for i in {1..60}; do curl -sf http://aspdotnetweb:5000/health > /dev/null 2>&1 && exit 0 || sleep 2; done; echo \"⚠️ Backend timeout\"; exit 0'",
    "wait-for-graphql": "bash -c 'for i in {1..60}; do curl -sf -H \"X-Allow-Introspection: true\" -X POST http://aspdotnetweb:5000/graphql -H \"Content-Type: application/json\" -d \"{\\\"query\\\":\\\"{__typename}\\\"}\" > /dev/null 2>&1 && exit 0 || sleep 2; done; echo \"⚠️ GraphQL timeout\"; exit 0'",
    "migrate": "cd ../aspnetcore && dotnet run --AppTasks=migrate",
    "revert:last": "cd ../aspnetcore && dotnet run --AppTasks=migrate.revert:last",
    "revert:all": "cd ../aspnetcore && dotnet run --AppTasks=migrate.revert:all"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "module",
  "dependencies": {
    "@grpc/grpc-js": "^1.13.4",
    "@grpc/proto-loader": "^0.8.0",
    "@improbable-eng/grpc-web": "^0.15.0",
    "@inertiajs/inertia": "^0.11.1",
    "@inertiajs/vue3": "^2.0.17",
    "@protobuf-ts/grpc-transport": "2.11.1",
    "@protobuf-ts/grpcweb-transport": "^2.11.1",
    "@protobuf-ts/runtime": "^2.11.1",
    "@protobuf-ts/runtime-rpc": "^2.11.1",
    "@speakeasy-api/speakeasy-client-sdk-typescript": "^3.3.15",
    "@vue/apollo-composable": "^4.2.2",
    "@vue/runtime-dom": "^3.5.18",
    "@vue/server-renderer": "^3.5.18",
    "@vuepic/vue-datepicker": "^12.0.1",
    "axios": "^1.11.0",
    "cross-fetch": "^4.1.0",
    "daisyui": "^5.0.50",
    "dayjs": "^1.11.19",
    "dotenv": "^17.2.3",
    "express": "^5.1.0",
    "google-protobuf": "^3.21.4",
    "graphql": "^16.11.0",
    "graphql-tag": "^2.12.6",
    "graphql-ws": "^6.0.6",
    "grpc_tools_node_protoc_ts": "^5.3.3",
    "grpc-tools": "^1.13.0",
    "grpc-web": "^1.5.0",
    "is-url-http": "^2.3.12",
    "mitt": "^3.0.1",
    "openapi-types": "^12.1.3",
    "openapi-zod-client": "^1.18.3",
    "path-to-regexp": "^6.3.0",
    "pinia": "^3.0.3",
    "postcss-fontpath": "^1.0.0",
    "prismjs": "^1.30.0",
    "protobufjs": "^7.5.3",
    "rxjs": "^7.8.2",
    "sax": "^1.4.3",
    "ts-protoc-gen": "^0.15.0",
    "tslib": "^2.8.1",
    "typed-openapi": "^2.2.3",
    "vue": "^3.5.18",
    "vue-router": "^4.6.3",
    "ws": "^8.18.3",
    "xmlbuilder": "^15.1.1",
    "xml2js": "^0.6.2",
    "zod": "^3.23.8",
    "zod-openapi": "^4.2.4"
  },
  "devDependencies": {
    "@apollo/client": "^3.8.9",
    "@apollo/rover": "^0.36.2",
    "@asteasolutions/zod-to-openapi": "^7.3.4",
    "@graphql-codegen/cli": "^5.0.7",
    "@graphql-codegen/client-preset": "^4.8.3",
    "@graphql-codegen/fragment-matcher": "^5.1.0",
    "@graphql-codegen/introspection": "^4.0.3",
    "@graphql-codegen/schema-ast": "^4.1.0",
    "@graphql-codegen/typed-document-node": "^5.1.2",
    "@graphql-codegen/typescript": "^5.0.2",
    "@graphql-codegen/typescript-operations": "^5.0.2",
    "@graphql-codegen/typescript-vue-apollo": "^4.1.2",
    "@graphql-inspector/cli": "^6.0.3",
    "@graphql-inspector/core": "^6.4.1",
    "@graphql-validate/cli": "^0.2.0",
    "@parcel/watcher": "^2.5.1",
    "@protobuf-ts/plugin": "^2.11.1",
    "@protobuf-ts/protoc": "^2.11.1",
    "@rollup/plugin-commonjs": "^25.0.7",
    "@rollup/plugin-inject": "^5.0.5",
    "@rollup/plugin-json": "^6.1.0",
    "@rollup/plugin-node-resolve": "^15.2.3",
    "@rollup/plugin-typescript": "^12.3.0",
    "@tailwindcss/cli": "^4.1.16",
    "@tailwindcss/forms": "^0.5.10",
    "@tailwindcss/node": "^4.1.16",
    "@tailwindcss/postcss": "^4.1.16",
    "@tailwindcss/vite": "^4.1.16",
    "@types/child-process-promise": "^2.2.6",
    "@types/google-protobuf": "^3.15.12",
    "@types/node": "^24.1.0",
    "@types/typography": "^0.16.8",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-vue": "^6.0.1",
