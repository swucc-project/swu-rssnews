    "eslint-plugin-jest": "^29.0.1",
    "eslint-plugin-node": "^11.1.0",
    "eslint-plugin-zod-openapi": "^2.0.0",
    "graphql": "^16.11.0",
    "graphql-cli": "^4.1.0",
    "graphql-json-to-sdl": "^0.5.0",
    "grpc_tools_node_protoc_ts": "^5.3.3",
    "jest": "^30.2.0",
    "laravel-vite-plugin": "^2.0.0",
    "lightningcss": "^1.30.2",
    "nodemon": "^3.1.10",
    "openapi-typescript": "^7.10.1",
    "openapi-zod": "^0.2.7",
    "postcss": "^8.5.6",
