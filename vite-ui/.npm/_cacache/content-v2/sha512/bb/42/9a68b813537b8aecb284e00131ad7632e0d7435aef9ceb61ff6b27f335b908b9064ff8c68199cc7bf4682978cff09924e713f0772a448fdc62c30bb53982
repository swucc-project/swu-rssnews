ser, { fetchUserById }){\n      return fetchUserById(user.id)\n    }\n  }\n};\n\nconst server = new ApolloServer({\n  schema: buildFederatedSchema([{ typeDefs, resolvers }])\n});\n```\n","engines":{"node":">=8"},"gitHead":"a2571cd6efae7e8c9bdfaa6351ec2e62dba4f5bf","_npmUser":{"name":"apollo-bot","email":"npm@apollographql.com"},"deprecated":"The @apollo/federation package is deprecated and will reach end-of-life September 22, 2023. It contains outdated utilities for both running subgraphs and composing supergraph schemas. Please migrate to the appropriate package for your use case (@apollo/subgraph or @apollo/composition). For more details, see our announcement blog post (https://www.apollographql.com/blog/announcement/backend/announcing-the-end-of-life-schedule-for-apollo-gateway-v0-x/) and documentation (https://www.apollographql.com/docs/federation/federation-2/backward-compatibility/#is-official-support-ending-for-apollogateway-v0x).","_npmVersion":"lerna/3.22.1/node@v10.22.0+x64 (linux)","description":"Apollo Federation Utilities","directories":{},"_nodeVersion":"10.22.0","dependencies":{"core-js":"^3.4.0","lodash.xorby":"^4.7.0","apollo-graphql":"^0.6.0","apollo-server-env":"^2.4.5"},"publishConfig":{"access":"public"},"_hasShrinkwrap":false,"readmeFilename":"README.md","peerDependencies":{"graphql":"^14.5.0 || ^15.0.0"},"_npmOperationalInternal":{"tmp":"tmp/federation_0.20.1-alpha.0_1599157378873_0.3177718515353585","host":"s3://npm-registry-packages"}},"0.20.1":{"name":"@apollo/federation","version":"0.20.1","keywords":["graphql","federation","apollo"],"author":{"name":"Apollo","email":"opensource@apollographql.com"},"license":"MIT","_id":"@apollo/federation@0.20.1","maintainers":[{"name":"apollo-bot","email":"npm@apollographql.com"}],"homepage":"https://github.com/apollographql/federation#readme","bugs":{"url":"https://github.com/apollographql/federation/issues"},"dist":{"shasum":"4b25a0141ca3300a0a2f107fa391f25bd4aab59f","tarball":"https://registry.npmjs.o