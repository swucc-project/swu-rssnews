lds: \"id\") {\n    id: ID!\n    username: String\n  }\n`;\n\nconst resolvers = {\n  Query: {\n    me() {\n      return { id: \"1\", username: \"@ava\" }\n    }\n  },\n  User: {\n    __resolveReference(user, { fetchUserById }){\n      return fetchUserById(user.id)\n    }\n  }\n};\n\nconst server = new ApolloServer({\n  schema: buildFederatedSchema([{ typeDefs, resolvers }])\n});\n```\n","engines":{"node":">=12.13.0 <17.0"},"gitHead":"fdccf9f4ea9db55a91f9ed12d6a15537c1b212a0","_npmUser":{"name":"apollo-bot","email":"npm@apollographql.com"},"deprecated":"The @apollo/federation package is deprecated and will reach end-of-life September 22, 2023. It contains outdated utilities for both running subgraphs and composing supergraph schemas. Please migrate to the appropriate package for your use case (@apollo/subgraph or @apollo/composition). For more details, see our announcement blog post (https://www.apollographql.com/blog/announcement/backend/announcing-the-end-of-life-schedule-for-apollo-gateway-v0-x/) and documentation (https://www.apollographql.com/docs/federation/federation-2/backward-compatibility/#is-official-support-ending-for-apollogateway-v0x).","repository":{"url":"git+https://github.com/apollographql/federation.git","type":"git","directory":"federation-js/"},"_npmVersion":"lerna/4.0.0/node@v12.22.3+x64 (linux)","description":"Apollo Federation Utilities","directories":{},"_nodeVersion":"12.22.3","dependencies":{"lodash.xorby":"^4.7.0","apollo-graphql":"^0.9.3"},"publishConfig":{"access":"public"},"_hasShrinkwrap":false,"readmeFilename":"README.md","peerDependencies":{"graphql":"^14.5.0 || ^15.0.0"},"_npmOperationalInternal":{"tmp":"tmp/federation_0.27.0-rc.0_1626718063881_0.032923691317764625","host":"s3://npm-registry-packages"}},"0.27.0":{"name":"@apollo/federation","version":"0.27.0","keywords":["graphql","federation","apollo"],"author":{"name":"Apollo","email":"opensource@apollographql.com"},"license":"MIT","_id":"@apollo/federation@0.27.0","maintainers":[