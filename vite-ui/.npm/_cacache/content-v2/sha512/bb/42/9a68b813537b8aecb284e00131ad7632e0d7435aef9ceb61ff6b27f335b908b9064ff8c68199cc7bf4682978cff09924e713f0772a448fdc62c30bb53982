ratedSchema([{ typeDefs, resolvers }])\n});\n```\n","engines":{"node":">=8"},"gitHead":"d4376a7d60c879244b04f73b072011a0dc8ff37c","_npmUser":{"name":"apollo-bot","email":"npm@apollographql.com"},"deprecated":"The @apollo/federation package is deprecated and will reach end-of-life September 22, 2023. It contains outdated utilities for both running subgraphs and composing supergraph schemas. Please migrate to the appropriate package for your use case (@apollo/subgraph or @apollo/composition). For more details, see our announcement blog post (https://www.apollographql.com/blog/announcement/backend/announcing-the-end-of-life-schedule-for-apollo-gateway-v0-x/) and documentation (https://www.apollographql.com/docs/federation/federation-2/backward-compatibility/#is-official-support-ending-for-apollogateway-v0x).","_npmVersion":"lerna/3.16.4/node@v11.14.0+x64 (darwin)","description":"Apollo Federation Utilities","directories":{},"_nodeVersion":"11.14.0","dependencies":{"apollo-env":"^0.5.1","lodash.xorby":"^4.7.0","apollo-graphql":"^0.3.3","apollo-server-env":"2.4.1"},"publishConfig":{"access":"public"},"_hasShrinkwrap":false,"readmeFilename":"README.md","peerDependencies":{"graphql":"^14.0.2"},"_npmOperationalInternal":{"tmp":"tmp/federation_0.8.1-alpha.0_1565296334919_0.10875155435023909","host":"s3://npm-registry-packages"}},"0.9.0":{"name":"@apollo/federation","version":"0.9.0","keywords":[],"author":{"name":"Apollo","email":"opensource@apollographql.com"},"license":"SEE LICENSE IN LICENSE.md","_id":"@apollo/federation@0.9.0","maintainers":[{"name":"apollo-bot","email":"npm@apollographql.com"}],"dist":{"shasum":"8a6b543c18726e8c99d2bd4cc1c84cf7bd6fe071","tarball":"https://registry.npmjs.org/@apollo/federation/-/federation-0.9.0.tgz","fileCount":262,"integrity":"sha512-WVxv6sSe3/3++J4ouoBOJCTjIlHDl47NGtQ0hTdjAquBfJXZzz96wBaMFHUGHQLw7SRLeae6KLWRfKt8RldZQw==","signatures":[{"sig":"MEUCIQC5Hj9Qup2LOLbRMv0v1FTmeen6gSS8oxsQMY4Fwuxt8AIgU3wAFn9TKL4BS/ZCF0dLI373CVHOxLAN0WqdN2EOz