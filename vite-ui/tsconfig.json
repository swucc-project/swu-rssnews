{
    "compilerOptions": {
        "target": "ES2020",
        "lib": [
            "ES2020",
            "DOM",
            "DOM.Iterable"
        ],
        "jsx": "preserve",
        "experimentalDecorators": true,
        "useDefineForClassFields": true,
        "module": "ESNext",
        "moduleResolution": "bundler",
        "resolveJsonModule": true,
        "allowImportingTsExtensions": true,
        "allowJs": true,
        "checkJs": false,
        "types": [
            "vite/client",
            "node",
            "@types/ws"
        ],
        "declaration": false,
        "sourceMap": true,
        "removeComments": false,
        "importsNotUsedAsValues": "remove",
        "isolatedModules": true,
        "allowSyntheticDefaultImports": true,
        "esModuleInterop": true,
        "forceConsistentCasingInFileNames": true,
        "verbatimModuleSyntax": false,
        "strict": true,
        "noEmit": true,
        "noUnusedLocals": false,
        "noUnusedParameters": false,
        "noFallthroughCasesInSwitch": true,
        "noUncheckedIndexedAccess": false,
        "noImplicitReturns": false,
        "noImplicitThis": true,
        "noImplicitAny": true,
        "resolvePackageJsonExports": true,
        "resolvePackageJsonImports": true,
        "strictNullChecks": true,
        "strictFunctionTypes": true,
        "strictBindCallApply": true,
        "strictPropertyInitialization": true,
        "alwaysStrict": true,
        "baseUrl": "./",
        "skipLibCheck": true,
        "skipDefaultLibCheck": true,
        "typeRoots": [
            "./node_modules/@types",
            "./node_modules/tailwindcss/types"
        ],
        "paths": {
            "~api/*": [
                "./api/*"
            ],
            "~apollo/*": [
                "./apollo/*"
            ],
            "~apollo/fragments": [
                "./apollo/generated/fragments.ts"
            ],
            "~apollo/generated": [
                "./apollo/generated/index.ts"
            ],
            "~apollo/generated/*": [
                "./apollo/generated/*"
            ],
            "~css/*": [
                "./css/*"
            ],
            "~fonts/*": [
                "./fonts/*"
            ],
            "~grpc/*": [
                "./grpc/*"
            ],
            "~grpc-generated/*": [
                "./grpc-generated/*"
            ],
            "~images/*": [
                "./images/*"
            ],
            "~joints/*": [
                "./hub/joints/*"
            ],
            "~schemas/*": [
                "./schemas/*"
            ],
            "~scripts/*": [
                "./scripts/*"
            ],
            "~tools/*": [
                "./tools/*"
            ],
            "@hub/*": [
                "./hub/*"
            ],
            "@generated": [
                "./apollo/generated/index.ts"
            ],
            "@generated/*": [
                "./apollo/generated/*"
            ],
            "@components/*": [
                "./hub/components/*"
            ],
            "@pages/*": [
                "./hub/Pages/*"
            ],
            "@suites/*": [
                "./hub/suites/*"
            ],
            "@/*": [
                "./hub/*"
            ],
        }
    },
    "include": [
        "hub/**/*",
        "api/**/*.ts",
        "apollo/**/*.ts",
        "apollo/**/*.d.ts",
        "grpc/**/*.ts",
        "grpc-generated/**/*.ts",
        "tools/**/*.ts",
        "schemas/**/*.ts",
        "scripts/**/*.ts",
        "vite.config.js",
        "*.d.ts"
    ],
    "exclude": [
        "node_modules",
        "dist",
        "wwwroot",
        "**/node_modules/**",
        "**/.git/**",
        "**/dist/**"
    ],
    "vueCompilerOptions": {
        "target": 3.3
    }
}