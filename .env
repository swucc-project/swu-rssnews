# Frontend - Server-side (Docker internal)
VITE_API_URL=http://aspdotnetweb:5000
VITE_GRAPHQL_ENDPOINT=http://aspdotnetweb:5000/graphql
VITE_GRAPHQL_WS_URL=ws://aspdotnetweb:5000/graphql-ws
VITE_GRPC_ENDPOINT=http://aspdotnetweb:5000/grpc

# Frontend - Client-side (Browser)
VITE_PUBLIC_API_URL=http://localhost:5000
VITE_PUBLIC_GRAPHQL_ENDPOINT=http://localhost:5000/graphql
VITE_PUBLIC_GRAPHQL_WS_URL=ws://localhost:5000/graphql-ws
VITE_PUBLIC_GRPC_ENDPOINT=http://localhost:5000/grpc

# SSR Configuration
SSR_RENDER_URL=http://frontend:13714/render
SSR_PORT=13714

# Backend Configuration
ASPNETCORE_ENVIRONMENT=Development
ASPNETCORE_URLS=http://+:5000
DATABASE_HOST=mssql
DATABASE_NAME=RSSActivityWeb
MSSQL_SA_PASSWORD_FILE=/run/secrets/db_password

# Migration
ADD_NEW_MIGRATION=true
MIGRATION_NAME=SWUNewsEvents

# Application
VITE_APP_ENV=development
VITE_APP_VERSION=1.0.0
PUBLIC_BASE_URL=http://localhost:8080
NODE_ENV=development
COMPOSE_PROFILES=setup,migration

# Production
PRODUCTION_URL=https://news.swu.ac.th

# Volume Management (for reference only - actual volumes are Docker managed)
COMPOSE_PROJECT_NAME=swu-rssnews