# ═══════════════════════════════════════════════════════════
# 🌐 Frontend URLs (Development)
# ═══════════════════════════════════════════════════════════
# Main application URL accessed via Nginx
APP_URL=http://localhost:8080
FRONTEND_URL=http://localhost:8080

# Vite Development Server
VITE_DEV_SERVER_PORT=5173
VITE_DEV_SERVER_URL=http://frontend:5173
VITE_DEV_PUBLIC_URL=http://localhost:5173

# ═══════════════════════════════════════════════════════════
# 🔗 API Endpoints - Docker Internal (Container-to-Container)
# ═══════════════════════════════════════════════════════════
VITE_API_URL=http://aspdotnetweb:5000
VITE_GRAPHQL_ENDPOINT=http://aspdotnetweb:5000/graphql
GRAPHQL_ENDPOINT=http://aspdotnetweb:5000/graphql
VITE_GRAPHQL_WS_URL=ws://aspdotnetweb:5000/graphql-ws
VITE_GRPC_ENDPOINT=http://aspdotnetweb:5000/grpc

# ═══════════════════════════════════════════════════════════
# 🌍 API Endpoints - Public (Browser-facing)
# ═══════════════════════════════════════════════════════════
VITE_PUBLIC_API_URL=http://localhost:8080
VITE_PUBLIC_GRAPHQL_ENDPOINT=http://localhost:8080/graphql
VITE_PUBLIC_GRAPHQL_WS_URL=ws://localhost:8080/graphql-ws
VITE_PUBLIC_GRPC_ENDPOINT=http://localhost:8080/grpc

# Vite App Configuration
VITE_APP_URL=http://localhost:8080
VITE_BASE_URL=/
VITE_APP_ENV=development
VITE_APP_VERSION=1.0.0

# ═══════════════════════════════════════════════════════════
# ⚙️ Backend Configuration
# ═══════════════════════════════════════════════════════════
ASPNETCORE_ENVIRONMENT=Development
ASPNETCORE_URLS=http://+:5000
ASPNETCORE_HTTP_PORTS=
ASPNETCORE_HTTPS_PORTS=
HTTP_PORTS=

# GraphQL Configuration
ENABLE_GRAPHQL_INTROSPECTION=true
ENABLE_GRAPHQL_PLAYGROUND=true
EXPORT_SCHEMA_ON_STARTUP=true
SCHEMA_EXPORT_PATH=/app/apollo/schema.graphql

# Kestrel Configuration
KESTREL_ENABLE_GRPC_WEB=true

# ═══════════════════════════════════════════════════════════
# 💾 Database Configuration
# ═══════════════════════════════════════════════════════════
DATABASE_HOST=mssql
DATABASE_NAME=RSSActivityWeb

# SQL Server Settings
MSSQL_PID=Express
MSSQL_AGENT_ENABLED=true
MSSQL_COLLATION=Thai_CI_AS
MSSQL_TCP_PORT=1433
MSSQL_MEMORY_LIMIT_MB=2048
MSSQL_SA_PASSWORD_FILE=/run/secrets/db_password

# ═══════════════════════════════════════════════════════════
# 🔧 Migration Configuration - DEVELOPMENT MODE
# ═══════════════════════════════════════════════════════════
# 🆕 ตั้งค่าสำหรับ Development Phase
# ────────────────────────────────────────────────────────────
# ⚠️ IMPORTANT: ตั้งค่าเป็น true สำหรับ development เท่านั้น
ADD_NEW_MIGRATION=true

# ชื่อ migration ที่จะสร้าง (default สำหรับ development)
MIGRATION_NAME=SWUNewsEvents

# ═══════════════════════════════════════════════════════════
# 🐳 Docker Configuration
# ═══════════════════════════════════════════════════════════
COMPOSE_PROJECT_NAME=swu-rssnews
DOCKER_CONTAINER=true
IS_DOCKER=true
NODE_ENV=development

# ═══════════════════════════════════════════════════════════
# ⏱️ Timeout Configuration - IMPROVED
# ═══════════════════════════════════════════════════════════
BACKEND_WAIT_TIMEOUT=300
GRAPHQL_WAIT_TIMEOUT=240
GRAPHQL_POLL_INTERVAL=2
ROVER_TIMEOUT=45
HEALTH_CHECK_RETRIES=5

# ═══════════════════════════════════════════════════════════
# 🎯 Feature Flags - IMPROVED
# ═══════════════════════════════════════════════════════════
WAIT_FOR_BACKEND=true
USE_PLACEHOLDER_ON_FAIL=false
CONTINUE_ON_GRAPHQL_FAIL=true
USE_LOCAL_SCHEMA=true
SKIP_GRAPHQL_CODEGEN=false
USE_CURL_FALLBACK=true
VALIDATE_SCHEMA=true
SCHEMA_VALIDATE_TIMEOUT=45
STRICT_MODE=false
CONTINUE_ON_FAIL=true
FORCE_PLACEHOLDERS=false

# ═══════════════════════════════════════════════════════════
# 🐛 Debug Configuration
# ═══════════════════════════════════════════════════════════
DEBUG_CODEGEN=false
CODEGEN_WATCH=false
VERBOSE=false
DEBUG=false

# ═══════════════════════════════════════════════════════════
# 🔑 Optional: Apollo Studio Integration
# ═══════════════════════════════════════════════════════════
# APOLLO_KEY=your-apollo-studio-api-key
# APOLLO_GRAPH_REF=rss-graph@swu

# ═══════════════════════════════════════════════════════════
# 🌏 Localization
# ═══════════════════════════════════════════════════════════
TZ=Asia/Bangkok
LANG=th_TH.UTF-8
LC_ALL=th_TH.UTF-8

# ═══════════════════════════════════════════════════════════
# 🔐 Security Notes
# ═══════════════════════════════════════════════════════════
# - Never commit actual secrets to git
# - Use ./secrets/db_password.txt for database password
# - Keep .env.production separate and secure
# - Review all URLs before deploying to production