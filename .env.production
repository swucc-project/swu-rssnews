# ═══════════════════════════════════════════════════════════
# 🚀 PRODUCTION CONFIGURATION
# ═══════════════════════════════════════════════════════════
# ⚠️ WARNING: This file contains production settings
# - Never commit actual secrets
# - Use secure password management
# - Review all URLs before deployment
# ═══════════════════════════════════════════════════════════

# ═══════════════════════════════════════════════════════════
# 🌐 Production URLs
# ═══════════════════════════════════════════════════════════
APP_URL=https://news.swu.ac.th
FRONTEND_URL=https://news.swu.ac.th
VITE_APP_URL=https://news.swu.ac.th
VITE_BASE_URL=/
PUBLIC_BASE_URL=https://news.swu.ac.th

# ═══════════════════════════════════════════════════════════
# 🌍 Public API Endpoints (Browser-facing)
# ═══════════════════════════════════════════════════════════
VITE_PUBLIC_API_URL=https://news.swu.ac.th
VITE_PUBLIC_GRAPHQL_ENDPOINT=https://news.swu.ac.th/graphql
VITE_PUBLIC_GRAPHQL_WS_URL=wss://news.swu.ac.th/graphql-ws
VITE_PUBLIC_GRPC_ENDPOINT=https://news.swu.ac.th/grpc

# ═══════════════════════════════════════════════════════════
# 🔗 Internal API Endpoints (Container-to-Container)
# ═══════════════════════════════════════════════════════════
VITE_API_URL=http://aspdotnetweb:5000
VITE_GRAPHQL_ENDPOINT=http://aspdotnetweb:5000/graphql
VITE_GRAPHQL_WS_URL=ws://aspdotnetweb:5000/graphql-ws
VITE_GRPC_ENDPOINT=http://aspdotnetweb:5000/grpc
GRAPHQL_URL=http://aspdotnetweb:5000/graphql
GRPC_URL=http://aspdotnetweb:5000/grpc

# ═══════════════════════════════════════════════════════════
# ⚙️ Backend Configuration
# ═══════════════════════════════════════════════════════════
ASPNETCORE_ENVIRONMENT=Production
ASPNETCORE_URLS=http://+:5000
ASPNETCORE_HTTP_PORTS=
ASPNETCORE_HTTPS_PORTS=
HTTP_PORTS=

# GraphQL Configuration (Production)
ENABLE_GRAPHQL_INTROSPECTION=false
ENABLE_GRAPHQL_PLAYGROUND=false

# Kestrel Configuration
KESTREL_ENABLE_GRPC_WEB=true

# ═══════════════════════════════════════════════════════════
# 💾 Database Configuration
# ═══════════════════════════════════════════════════════════
DATABASE_HOST=mssql
DATABASE_NAME=RSSActivityWeb
MSSQL_SA_PASSWORD_FILE=/run/secrets/db_password

# SQL Server Settings
MSSQL_PID=Express
MSSQL_AGENT_ENABLED=true
MSSQL_COLLATION=Thai_CI_AS
MSSQL_TCP_PORT=1433
MSSQL_MEMORY_LIMIT_MB=4096

# ═══════════════════════════════════════════════════════════
# 🔧 Migration Configuration
# ═══════════════════════════════════════════════════════════
ADD_NEW_MIGRATION=false
MIGRATION_NAME=

# ═══════════════════════════════════════════════════════════
# 🐳 Docker Configuration
# ═══════════════════════════════════════════════════════════
COMPOSE_PROJECT_NAME=swu-rssnews
DOCKER_CONTAINER=true
IS_DOCKER=true
NODE_ENV=production

# Application Info
VITE_APP_ENV=production
VITE_APP_VERSION=1.0.0

# ═══════════════════════════════════════════════════════════
# ⏱️ Timeout Configuration (Production)
# ═══════════════════════════════════════════════════════════
BACKEND_WAIT_TIMEOUT=60
GRAPHQL_WAIT_TIMEOUT=30

# ═══════════════════════════════════════════════════════════
# 🎯 Feature Flags (Production)
# ═══════════════════════════════════════════════════════════
WAIT_FOR_BACKEND=false
USE_PLACEHOLDER_ON_FAIL=false
CONTINUE_ON_GRAPHQL_FAIL=false
SKIP_GRAPHQL_CODEGEN=true
DEBUG_CODEGEN=false
CODEGEN_WATCH=false

# ═══════════════════════════════════════════════════════════
# 🔑 Optional: Apollo Studio Integration
# ═══════════════════════════════════════════════════════════
# APOLLO_KEY=your-production-apollo-key
# APOLLO_GRAPH_REF=rss-graph@swu

# ═══════════════════════════════════════════════════════════
# 🌏 Localization
# ═══════════════════════════════════════════════════════════
TZ=Asia/Bangkok
LANG=th_TH.UTF-8
LC_ALL=th_TH.UTF-8

# ═══════════════════════════════════════════════════════════
# 🔐 Security Reminders
# ═══════════════════════════════════════════════════════════
# ✅ Introspection disabled
# ✅ GraphQL Playground disabled
# ✅ Debug modes disabled
# ✅ Secrets managed via Docker secrets
# ✅ HTTPS enforced for all public endpoints