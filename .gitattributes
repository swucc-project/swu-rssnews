# Auto detect text files and normalize line endings
* text=auto eol=lf

# Shell scripts must use LF
*.sh text eol=lf
*.bash text eol=lf

# PowerShell can use CRLF
*.ps1 text eol=crlf
*.psm1 text eol=crlf

# Docker files use LF
Dockerfile text eol=lf
docker-compose*.yml text eol=lf
*.dockerfile text eol=lf

# JavaScript/TypeScript
*.js text eol=lf
*.ts text eol=lf
*.mjs text eol=lf
*.cjs text eol=lf
*.jsx text eol=lf
*.tsx text eol=lf
*.json text eol=lf

# Config files
*.yml text eol=lf
*.yaml text eol=lf
*.toml text eol=lf
*.xml text eol=lf
*.conf text eol=lf
*.config text eol=lf

# Web files
*.html text eol=lf
*.css text eol=lf
*.scss text eol=lf
*.vue text eol=lf
*.svelte text eol=lf

# C#
*.cs text eol=lf
*.csproj text eol=lf
*.sln text eol=lf

# Binary files
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.woff binary
*.woff2 binary
*.ttf binary
*.eot binary
*.pdf binary